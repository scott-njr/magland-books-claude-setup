# Public site URL (used for canonical, sitemap, OG metadata)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Resend — transactional email (contact form) + newsletter audience
# Sign up at https://resend.com, verify the maglandbooks.com domain (DNS records),
# then create an API key + an Audience for newsletter signups.
RESEND_API_KEY=
RESEND_NEWSLETTER_AUDIENCE_ID=

# Square checkout — sandbox values for dev, production values when cutting over
NEXT_PUBLIC_SQUARE_APPLICATION_ID=
NEXT_PUBLIC_SQUARE_LOCATION_ID=
SQUARE_ACCESS_TOKEN=
SQUARE_ENVIRONMENT=sandbox
SQUARE_WEBHOOK_SIGNATURE_KEY=
